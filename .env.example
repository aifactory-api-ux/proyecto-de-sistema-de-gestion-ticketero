# Ticket System Environment Variables
# Copy this file to .env and configure the values

# ============================================================================
# TELEGRAM CONFIGURATION
# ============================================================================

# Telegram Bot API Token
# Get this from @BotFather on Telegram
# Example: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Public webhook URL for Telegram bot
# This must be a publicly accessible URL for webhooks to work
# Example: https://myapp.onrender.com/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================


# Backend host (usually 0.0.0.0 for Docker)
BACKEND_HOST=0.0.0.0

# Backend port (must be 8001 for this project)
BACKEND_PORT=8001

# Database URL (SQLite path)
# Format: sqlite:///./path/to/db.db
DATABASE_URL=sqlite:///./tickets.db

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend port
FRONTEND_PORT=20001

# API URL for frontend (service name for Docker)
# Do NOT use localhost - use the Docker service name
API_URL=http://backend:2000301

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================

# Enable debug logging (true/false)
DEBUG=false

# Timezone for containers
# Example: America/Argentina/Buenos_Aires, UTC, Europe/Madrid
TZ=America/Argentina/Buenos_Aires

# Frontend API URLs (auto-generadas por TechLeadRunner)
NEXT_PUBLIC_API_URL=http://localhost:20001
VITE_API_URL=http://localhost:20001
